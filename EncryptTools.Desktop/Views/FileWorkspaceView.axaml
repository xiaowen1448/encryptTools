<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:EncryptTools.Desktop.Views"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             x:Class="EncryptTools.Desktop.Views.FileWorkspaceView"
             x:CompileBindings="False"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
    <Grid RowDefinitions="Auto,*,Auto" Margin="6" VerticalAlignment="Stretch" MinHeight="200">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <WrapPanel Orientation="Horizontal">
                <Button Name="BtnAddFiles" Content="添加文件" Margin="0,0,6,4" />
                <Button Name="BtnAddFolder" Content="添加文件夹" Margin="0,0,6,4" />
                <Button Name="BtnClear" Content="清空列表" Margin="0,0,6,4" />
                <Button Name="BtnPastePaths" Content="粘贴路径" Margin="0,0,12,4"
                        ToolTip.Tip="从剪贴板读取路径（与拖放相同规则）。若拖入无效（常见于 Wayland），请在文件管理器中复制文件/文件夹后点此处。" />
                <TextBlock Text="密码文件:" VerticalAlignment="Center" Margin="0,0,4,4" />
                <ComboBox Name="CbPwdFile" Width="140" Margin="0,0,12,4" />
                <TextBlock Text="算法:" VerticalAlignment="Center" Margin="0,0,4,4" />
                <ComboBox Name="CbAlgo" Width="130" Margin="0,0,12,4" />
                <TextBlock Text="后缀:" VerticalAlignment="Center" Margin="0,0,4,4" />
                <ComboBox Name="CbSuffix" Width="100" Margin="0,0,12,4" />
                <CheckBox Name="ChkOverwrite" Content="覆盖原文件" Margin="0,0,8,4" IsChecked="True" />
                <CheckBox Name="ChkRecursive" Content="递归子目录" Margin="0,0,8,4" IsChecked="True" />
                <CheckBox Name="ChkRandomName" Content="随机文件名" Margin="0,0,8,4" />
                 <Button Name="BtnEncrypt" Content="加密" Background="#4169E1" Foreground="White" Margin="0,0,6,4"  MinWidth="88" />
                 <Button Name="BtnDecrypt" Content="解密" Background="#2E8B57" Foreground="White" Margin="0,0,6,4" MinWidth="88" />
                <Button Name="BtnCancel" Content="取消" MinWidth="88" Margin="0,0,6,4"  IsEnabled="False" />
            </WrapPanel>
        </ScrollViewer>
        <Border Name="DropZone" Grid.Row="1" BorderBrush="#ccc" BorderThickness="1" Margin="0,4,0,4"
                VerticalAlignment="Stretch" MinHeight="120" Background="Transparent">
            <!-- DataGrid：列宽均分（*），表头可拖动调整；进度条随列宽拉伸，与其它列视觉一致 -->
            <dg:DataGrid Name="FilePathsGrid"
                         AutoGenerateColumns="False"
                         CanUserResizeColumns="True"
                         CanUserReorderColumns="False"
                         GridLinesVisibility="Horizontal"
                         HeadersVisibility="Column"
                         IsReadOnly="True"
                         Background="Transparent"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto">
                <dg:DataGrid.Columns>
                    <dg:DataGridTemplateColumn Header="名称" Width="*" MinWidth="72">
                        <dg:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="views:FileWorkspaceRow">
                                <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" Margin="4,2"
                                           ToolTip.Tip="{Binding FullPath}" />
                            </DataTemplate>
                        </dg:DataGridTemplateColumn.CellTemplate>
                    </dg:DataGridTemplateColumn>
                    <dg:DataGridTemplateColumn Header="路径" Width="*" MinWidth="96">
                        <dg:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="views:FileWorkspaceRow">
                                <TextBlock Text="{Binding FullPath}" TextTrimming="CharacterEllipsis"
                                           FontSize="11" Foreground="#666666" VerticalAlignment="Center" Margin="4,2"
                                           ToolTip.Tip="{Binding FullPath}" />
                            </DataTemplate>
                        </dg:DataGridTemplateColumn.CellTemplate>
                    </dg:DataGridTemplateColumn>
                    <dg:DataGridTemplateColumn Header="大小" Width="*" MinWidth="56">
                        <dg:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="views:FileWorkspaceRow">
                                <TextBlock Text="{Binding SizeText}" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" Margin="4,2" />
                            </DataTemplate>
                        </dg:DataGridTemplateColumn.CellTemplate>
                    </dg:DataGridTemplateColumn>
                    <dg:DataGridTemplateColumn Header="类型" Width="*" MinWidth="48">
                        <dg:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="views:FileWorkspaceRow">
                                <TextBlock Text="{Binding TypeText}" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" Margin="4,2" />
                            </DataTemplate>
                        </dg:DataGridTemplateColumn.CellTemplate>
                    </dg:DataGridTemplateColumn>
                    <dg:DataGridTemplateColumn Header="状态" Width="*" MinWidth="64">
                        <dg:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="views:FileWorkspaceRow">
                                <TextBlock Text="{Binding StatusText}" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" Margin="4,2" />
                            </DataTemplate>
                        </dg:DataGridTemplateColumn.CellTemplate>
                    </dg:DataGridTemplateColumn>
                    <dg:DataGridTemplateColumn Header="进度" Width="*" MinWidth="88">
                        <dg:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="views:FileWorkspaceRow">
                                <Grid MinHeight="22" Margin="4,2" VerticalAlignment="Center">
                                    <!-- 两条 ProgressBar：XAML 写死红/绿；IBrush 绑定在 DataGrid 单元格内常不生效（指示条呈灰） -->
                                    <ProgressBar Minimum="0" Maximum="100" Height="14"
                                                 HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                 Value="{Binding ProgressBarValue, Mode=OneWay}"
                                                 Foreground="#D32F2F"
                                                 IsVisible="{Binding ShowEncryptProgressBar}" />
                                    <ProgressBar Minimum="0" Maximum="100" Height="14"
                                                 HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                 Value="{Binding ProgressBarValue, Mode=OneWay}"
                                                 Foreground="#4CAF50"
                                                 IsVisible="{Binding ShowDecryptProgressBar}" />
                                    <TextBlock Text="{Binding ProgressLabel}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="11" IsHitTestVisible="False"
                                               IsVisible="{Binding ShowIdleLabel}" />
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"
                                               Text="{Binding ProgressLabel}" IsHitTestVisible="False"
                                               IsVisible="{Binding ShowProgressBar}" />
                                </Grid>
                            </DataTemplate>
                        </dg:DataGridTemplateColumn.CellTemplate>
                    </dg:DataGridTemplateColumn>
                </dg:DataGrid.Columns>
            </dg:DataGrid>
        </Border>
     
    </Grid>
</UserControl>
